# ═══════════════════════════════════════════
#  工程运维 ERP — 生产环境变量
#  路径: /etc/ops-erp/ops-erp.env
#  权限: chmod 600 ops-erp.env
# ═══════════════════════════════════════════

# ── 数据库（PostgreSQL） ──
DB_URL=jdbc:postgresql://localhost:5432/ops_erp
DB_USERNAME=ops_erp
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── JWT ──
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING
JWT_EXPIRE_MINUTES=30
ALLOWED_ORIGINS=https://erp.example.com
DATA_ENCRYPTION_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_SECRET

# ── 首次启动管理员（只在账号不存在时创建，之后不会覆盖密码） ──
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
BOOTSTRAP_ADMIN_DISPLAY_NAME=系统管理员

# ── 对象存储（MinIO / S3 兼容） ──
STORAGE_TYPE=minio
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=ops_erp_minio
MINIO_SECRET_KEY=CHANGE_ME_MINIO_PASSWORD
MINIO_BUCKET=ops-erp
MINIO_PRESIGNED_EXPIRY_SECONDS=600

# ── Spring Profile（固定为 prod） ──
SPRING_PROFILES_ACTIVE=prod

# 仅旧版 V77 数据库升级到基线构建时启用；全新部署不要配置：
# SPRING_FLYWAY_IGNORE_MIGRATION_PATTERNS=*:missing,*:ignored
# SPRING_FLYWAY_VALIDATE_ON_MIGRATE=false
